
# Variables
CA_IP = "10.0.0.1"
WEBSERVERS = [
  { name: "webserver1", ip: "10.0.0.2" },
  { name: "webserver2", ip: "10.0.0.3" },
]

Vagrant.configure("2") do |config|
	config.vm.box = "ubuntu/jammy64"

	# VM 1: Certificate Authority
	config.vm.define "ca" do |ca|
		ca.vm.hostname = "ca"
		ca.vm.network "private_network", ip: CA_IP
		ca.vm.provider "virtualbox" do |vb|
			vb.name = "ca"
			vb.memory = 512
			vb.cpus = 1
		end #ends VB-conf

		ca.vm.provision "shell", inline: <<-SHELL
      		apt-get update -y
      		apt-get install -y ansible

      	# Generate SSH keys 
      		sudo -u vagrant ssh-keygen -t ed25519 \
        		-f /home/vagrant/.ssh/id_ed25519 \
        		-N "" -C "ansible-kontroll" 

      	# Copy public key to shared folder
      		cp /home/vagrant/.ssh/id_ed25519.pub \
         	/vagrant/ansible_id_ed25519.pub

      		echo "=== CA done ==="
    	SHELL
	end #End VM1

	# VM 2: Webserver
	 WEBSERVERS.each do |ws|
		config.vm.define ws[:name] do |web|
			web.vm.hostname = ws[:name]
			web.vm.network "private_network", ip: ws[:ip]
			web.vm.provider "virtualbox" do |vb|
				vb.name = ws[:name]
				vb.memory = 512
				vb.cpus = 1
			end #End VB-conf

			# Make sure that VM1's public key is generated
			web.vm.provision "shell", inline: <<-SHELL		
				while [ ! -f /vagrant/ansible_id_ed25519.pub ]; do
					sleep 3
				done

				# Create folders and copy over public key from VM1
				mkdir -p /home/vagrant/.ssh
				if ! grep -qF "$(cat /vagrant/ansible_id_ed25519.pub)" /home/vagrant/.ssh/authorized_keys 2>/dev/null; then
					cat /vagrant/ansible_id_ed25519.pub >> /home/vagrant/.ssh/authorized_keys
				fi
				chmod 700 /home/vagrant/.ssh
				chmod 600 /home/vagrant/.ssh/authorized_keys
				chown -R vagrant:vagrant /home/vagrant/.ssh
		
				echo "=== #{ws[:name]} done ==="
			SHELL
		end #End VM2
	end


end #End all
	